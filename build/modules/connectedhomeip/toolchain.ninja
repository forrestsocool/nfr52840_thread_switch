rule copy
  command = cmd /c "(cp -af ${in} ${out} > NUL 2>&1) || (python C:/ncs/v3.2.1/modules/lib/matter/third_party/pigweed/repo/pw_toolchain/py/pw_toolchain/copy_with_metadata.py ${in} ${out})"
  description = cp ${in} ${out}
rule stamp
  command = cmd /c type nul > "${out}"
  description = stamp ${out}
rule cc
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc.exe -MMD -MF ${out}.d ${cflags} ${cflags_c} ${defines} ${include_dirs} -c ${in} -o ${out}
  description = cc ${out}
  depfile = ${out}.d
  deps = gcc
rule cxx
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-g++.exe -MMD -MF ${out}.d ${cflags} ${cflags_cc} ${defines} ${include_dirs} -c ${in} -o ${out}
  description = c++ ${out}
  depfile = ${out}.d
  deps = gcc
rule alink
  command = cmd /c "(del /F /Q "${out}" 2> NUL) & C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-ar.exe ${arflags} rcs ${out} @${out}.rsp"
  description = ar ${target_output_name}${output_extension}
  rspfile = ${out}.rsp
  rspfile_content = ${in}
rule solink
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-g++.exe ${ldflags} @${output_dir}/${target_output_name}${output_extension}.rsp -o ${output_dir}/${target_output_name}${output_extension} -shared
  description = ld -shared ${output_dir}/${target_output_name}${output_extension}
  rspfile = ${output_dir}/${target_output_name}${output_extension}.rsp
  rspfile_content = -Wl,--start-group ${in} ${frameworks} ${libs} -Wl,--end-group
rule link
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-g++.exe ${ldflags} @${output_dir}/${target_output_name}${output_extension}.rsp -o ${output_dir}/${target_output_name}${output_extension}
  description = ld ${output_dir}/${target_output_name}${output_extension}
  rspfile = ${output_dir}/${target_output_name}${output_extension}.rsp
  rspfile_content = -Wl,--start-group ${in} ${frameworks} ${libs} -Wl,--end-group
rule objc
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc.exe -MMD -MF ${out}.d ${cflags} ${cflags_objc} ${defines} ${include_dirs} ${framework_dirs} -c ${in} -o ${out}
  description = objc ${out}
  depfile = ${out}.d
  deps = gcc
rule objcxx
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-g++.exe -MMD -MF ${out}.d ${cflags} ${cflags_objcc} ${defines} ${include_dirs} ${framework_dirs} -c ${in} -o ${out}
  description = objc++ ${out}
  depfile = ${out}.d
  deps = gcc
rule asm
  command = C:/ncs/toolchains/66cdf9b75e/opt/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc.exe -MMD -MF ${out}.d ${asmflags} ${cflags} ${defines} ${include_dirs} -c ${in} -o ${out}
  description = as ${out}
