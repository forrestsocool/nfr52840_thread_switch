ninja_required_version = 1.7.2

rule gn
  command = C:/ncs/toolchains/66cdf9b75e/opt/bin/gn.exe --root=C:/ncs/v3.2.1/modules/lib/matter -q --dotfile=C:/ncs/v3.2.1/modules/lib/matter/config/nrfconnect/chip-gn/.gn --check --export-compile-commands --fail-on-unused-args --root-target=C$:/ncs/v3.2.1/modules/lib/matter/config/nrfconnect/chip-gn --script-executable=C$:/ncs/toolchains/66cdf9b75e/opt/bin/python.exe --regeneration gen .
  pool = console
  description = Regenerating ninja files

# The 'gn' rule also writes build.ninja, unbeknownst to ninja. The
# build.ninja edge is separate to prevent ninja from deleting it
# (due to depfile usage) if interrupted. gn uses atomic writes to
# ensure that build.ninja is always valid even if interrupted.
build build.ninja.stamp: gn
  generator = 1
  depfile = build.ninja.d

build build.ninja: phony build.ninja.stamp
  generator = 1

pool third_party_pigweed_repo_pw_build_pool_pip
  depth = 1

subninja toolchain.ninja
subninja protocol_buffer/toolchain.ninja
subninja python/toolchain.ninja

