defines = -DNDEBUG -DCHIP_HAVE_CONFIG_H=1
framework_dirs =
include_dirs = -IC$:/ncs/v3.2.1/modules/lib/matter/src/include -IC$:/ncs/v3.2.1/modules/lib/matter/src -Igen/include -IC$:/ncs/v3.2.1/modules/lib/matter/zzz_generated/app-common -IC$:/ncs/v3.2.1/modules/lib/matter/third_party/nlassert/repo/include -IC$:/ncs/v3.2.1/modules/lib/matter/third_party/nlio/repo/include
